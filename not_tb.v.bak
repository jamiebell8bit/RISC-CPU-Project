// "Not" TB Code
// Group: 22

// datapath_tb.v file for NOT R4, R7:
`timescale 1ns/10ps 
module datapath_not_tb;       
    reg PCout, Zlowout, MDRout, R7out, R4out;  // R7 and R4 registers      
    reg MARin, Zin, PCin, MDRin, IRin, Yin;    
    reg IncPC, Read, NOT, R4in, R7in;  // NOT control signal (changed from NEG)
    reg Clock; 
    reg [31:0] Mdatain;      
    
    // add any other signals to see in your simulation 
    parameter  Default = 4'b0000, Reg_load1a = 4'b0001, Reg_load1b = 4'b0010, 
               T0 = 4'b0011, T1 = 4'b0100, T2 = 4'b0101, T3 = 4'b0110, T4 = 4'b0111;
    
    reg [3:0] Present_state = Default; 
    
    Datapath DUT(
        PCout, Zlowout, MDRout, R7out, R4out, 
        MARin, Zin, PCin, MDRin, IRin, Yin, 
        IncPC, Read, NOT, R4in, R7in,  // Changed NEG to NOT
        Clock, Mdatain
    ); 
    
    // Clock generation
    initial begin 
        Clock = 0; 
        forever #10 Clock = ~ Clock; 
    end 
    
    // State machine - update on positive clock edge
    always @(posedge Clock) begin 
        case (Present_state) 
            Default:      Present_state = Reg_load1a; 
            Reg_load1a:   Present_state = Reg_load1b; 
            Reg_load1b:   Present_state = T0; 
            T0:           Present_state = T1; 
            T1:           Present_state = T2; 
            T2:           Present_state = T3; 
            T3:           Present_state = T4; 
            T4:           Present_state = T0; // Loop back or end simulation
        endcase 
    end 
    
    // Control signal generation based on current state
    always @(Present_state) begin 
        case (Present_state)               
            Default: begin 
                // Initialize all signals to 0
                {PCout, Zlowout, MDRout, R7out, R4out} = 5'b0;
                {MARin, Zin, PCin, MDRin, IRin, Yin} = 6'b0;
                {IncPC, Read, NOT, R4in, R7in} = 5'b0;  // Changed NEG to NOT
                Mdatain = 32'h00000000;
            end 
            
            Reg_load1a: begin   // Load R7 with test value (e.g., 0x19 = 25)
                Mdatain = 32'h00000019;  // 000...00011001 binary
                Read = 1; 
                MDRin = 1;              
            end 
            
            Reg_load1b: begin   // Transfer from MDR to R7
                MDRout = 1; 
                R7in = 1;     
            end 
            
            T0: begin   // Fetch: PC -> MAR, PC+1 -> Z
                PCout = 1; 
                MARin = 1; 
                IncPC = 1; 
                Zin = 1;   
            end 
            
            T1: begin   // Fetch: Z -> PC, Read memory, Mdatain = instruction
                Zlowout = 1; 
                PCin = 1; 
                Read = 1; 
                MDRin = 1;   
                Mdatain = 32'h154B0000;  // not R4, R7 opcode (example - different from NEG)
            end 
            
            T2: begin   // Fetch: MDR -> IR
                MDRout = 1; 
                IRin = 1;    
            end 
            
            T3: begin   // Execute: R7 -> NOT -> Z (bitwise NOT of R7)
                R7out = 1; 
                NOT = 1;    // NOT operation (bitwise complement)
                Zin = 1;    // Store result in Z
            end 
            
            T4: begin   // Writeback: Z -> R4
                Zlowout = 1; 
                R4in = 1;   // Store NOT result in R4
            end 
            
        endcase 
    end 
    
endmodule