// ALU code (Phase 1 compliant)
// - ADD/SUB implemented via adder32 (NO + / -)
// - MUL/DIV implemented via mul.v / div.v (NO * / / %)
// Group: 22

module alu (
    input  [31:0] A,
    input  [31:0] B,
    input  [4:0]  ALUop,
    output reg [63:0] Z
);

    // ----------------------------
    // ADD / SUB (no + / -)
    // ----------------------------
    wire isSUB = (ALUop == 5'd1);   // 0=ADD, 1=SUB
    wire [31:0] addsub_S;
    wire addsub_Cout;

    adder32 U_ADD_SUB (
        .A(A),
        .B(B),
        .SUB(isSUB),
        .S(addsub_S),
        .Cout(addsub_Cout)
    );

    // NEG: Z = -A (0 - A using adder32)
    wire [31:0] neg_S;
    wire neg_Cout;

    adder32 U_NEG (
        .A(32'b0),
        .B(A),
        .SUB(1'b1),
        .S(neg_S),
        .Cout(neg_Cout)
    );

    // ----------------------------
    // MUL / DIV modules
    // ----------------------------
    wire [63:0] mul_Z;
    wire [63:0] div_Z;

    mul U_MUL (
        .A(A),
        .B(B),
        .P(mul_Z)
    );

    div U_DIV (
        .A(A),
        .B(B),
        .QR(div_Z)   // {remainder, quotient}
    );

    // ----------------------------
    // Shifts / rotates
    // ----------------------------
    wire [4:0] shamt = B[4:0];
    wire [31:0] rol  = (A << shamt) | (A >> (5'd32 - shamt));
    wire [31:0] ror  = (A >> shamt) | (A << (5'd32 - shamt));

    // ----------------------------
    // ALU operation select
    // ----------------------------
    always @(*) begin
        case (ALUop)
            5'd0:  Z = {32'b0, addsub_S};                // ADD
            5'd1:  Z = {32'b0, addsub_S};                // SUB
            5'd2:  Z = {32'b0, (A & B)};                 // AND
            5'd3:  Z = {32'b0, (A | B)};                 // OR
            5'd4:  Z = {32'b0, neg_S};                   // NEG
            5'd5:  Z = {32'b0, (~A)};                    // NOT
            5'd6:  Z = {32'b0, (A << shamt)};            // SHL
            5'd7:  Z = {32'b0, (A >> shamt)};            // SHR (logical)
            5'd8:  Z = {32'b0, ($signed(A) >>> shamt)};  // SHRA
            5'd9:  Z = {32'b0, rol};                     // ROL
            5'd10: Z = {32'b0, ror};                     // ROR
            5'd11: Z = mul_Z;                            // MUL (64-bit)
            5'd12: Z = div_Z;                            // DIV -> {rem, quo}
            default: Z = 64'b0;
        endcase
    end

endmodule