// "And" Tb Code
// Group: 22

// datapath_tb.v file:
`timescale 1ns/10ps 
module datapath_tb;       
    reg PCout, Zlowout, MDRout, R5out, R6out;           
    reg MARin, Zin, PCin, MDRin, IRin, Yin;    
    reg IncPC, Read, AND, R2in, R5in, R6in; 
    reg Clock; 
    reg [31:0] Mdatain;      
    
    // add any other signals to see in your simulation 
    parameter  Default = 4'b0000, Reg_load1a = 4'b0001, Reg_load1b = 4'b0010, 
               Reg_load2a = 4'b0011, Reg_load2b = 4'b0100, Reg_load3a = 4'b0101, 
               Reg_load3b = 4'b0110, T0 = 4'b0111, T1 = 4'b1000, T2 = 4'b1001, 
               T3 = 4'b1010, T4 = 4'b1011, T5 = 4'b1100; 
    
    reg [3:0] Present_state = Default; 
    
    Datapath DUT(
        PCout, Zlowout, MDRout, R5out, R6out, 
        MARin, Zin, PCin, MDRin, IRin, Yin, 
        IncPC, Read, AND, R2in, R5in, R6in, 
        Clock, Mdatain
    ); 
    
    // Clock generation
    initial begin 
        Clock = 0; 
        forever #10 Clock = ~ Clock; 
    end 
    
    // State machine - update on positive clock edge
    always @(posedge Clock) begin 
        case (Present_state) 
            Default:      Present_state = Reg_load1a; 
            Reg_load1a:   Present_state = Reg_load1b; 
            Reg_load1b:   Present_state = Reg_load2a; 
            Reg_load2a:   Present_state = Reg_load2b; 
            Reg_load2b:   Present_state = Reg_load3a; 
            Reg_load3a:   Present_state = Reg_load3b; 
            Reg_load3b:   Present_state = T0; 
            T0:           Present_state = T1; 
            T1:           Present_state = T2; 
            T2:           Present_state = T3; 
            T3:           Present_state = T4; 
            T4:           Present_state = T5; 
            T5:           Present_state = T0; // Loop back or end simulation
        endcase 
    end 
    
    // Control signal generation based on current state
    always @(Present_state) begin 
        case (Present_state)               
            Default: begin 
                // Initialize all signals to 0
                {PCout, Zlowout, MDRout, R5out, R6out} = 5'b0;
                {MARin, Zin, PCin, MDRin, IRin, Yin} = 6'b0;
                {IncPC, Read, AND, R2in, R5in, R6in} = 6'b0;
                Mdatain = 32'h00000000;
            end 
            
            Reg_load1a: begin   // Load R5 with 0x34
                Mdatain = 32'h00000034; 
                Read = 1; 
                MDRin = 1;              
            end 
            
            Reg_load1b: begin   // Transfer from MDR to R5
                MDRout = 1; 
                R5in = 1;     
            end 
            
            Reg_load2a: begin   // Load R6 with 0x45
                Mdatain = 32'h00000045; 
                Read = 1; 
                MDRin = 1;   
            end 
            
            Reg_load2b: begin   // Transfer from MDR to R6
                MDRout = 1; 
                R6in = 1;   
            end 
            
            Reg_load3a: begin   // Load R2 with initial value (optional)
                Mdatain = 32'h00000067; 
                Read = 1; 
                MDRin = 1; 
            end 
            
            Reg_load3b: begin   // Transfer from MDR to R2
                MDRout = 1; 
                R2in = 1; 
            end 
            
            T0: begin   // Fetch: PC -> MAR, PC+1 -> Z
                PCout = 1; 
                MARin = 1; 
                IncPC = 1; 
                Zin = 1;   
            end 
            
            T1: begin   // Fetch: Z -> PC, Read memory, Mdatain = instruction
                Zlowout = 1; 
                PCin = 1; 
                Read = 1; 
                MDRin = 1;   
                Mdatain = 32'h112B0000;  // and R2, R5, R6 opcode
            end 
            
            T2: begin   // Fetch: MDR -> IR
                MDRout = 1; 
                IRin = 1;    
            end 
            
            T3: begin   // Execute: R5 -> Y
                R5out = 1; 
                Yin = 1;    
            end 
            
            T4: begin   // Execute: R6 AND Y -> Z
                R6out = 1; 
                AND = 1; 
                Zin = 1;    
            end 
            
            T5: begin   // Writeback: Z -> R2
                Zlowout = 1; 
                R2in = 1;   
            end 
            
        endcase 
    end 
    
endmodule