// Datapath Testbench (Phase 1)
// Group: 22

`timescale 1ns/1ps

module datapath_tb;

reg clock;
reg clear;

// Control signals
reg [15:0] Rin;
reg [15:0] Rout;

reg PCin, PCout;
reg IRin, IRout;
reg MARin;
reg MDRin, MDRout;
reg HIin, HIout;
reg LOin, LOout;
reg Yin;
reg Zin;
reg Zhighout;
reg Zlowout;

reg read;
reg [4:0] ALUop;

reg [31:0] Mdatain;

// Outputs
wire [31:0] BusMuxOut;
wire [31:0] IR_q;
wire [31:0] MDR_q;
wire [8:0]  MAR_addr;
wire [31:0] HI_q;
wire [31:0] LO_q;
wire [31:0] Y_q;
wire [63:0] Z_q;


// Instantiate datapath
datapath DUT (
    .clock(clock),
    .clear(clear),

    .Rin(Rin),
    .Rout(Rout),

    .PCin(PCin), .PCout(PCout),
    .IRin(IRin), .IRout(IRout),
    .MARin(MARin),
    .MDRin(MDRin), .MDRout(MDRout),
    .HIin(HIin), .HIout(HIout),
    .LOin(LOin), .LOout(LOout),
    .Yin(Yin),
    .Zin(Zin),
    .Zhighout(Zhighout),
    .Zlowout(Zlowout),

    .read(read),
    .ALUop(ALUop),

    .Mdatain(Mdatain),

    .BusMuxOut(BusMuxOut),
    .IR_q(IR_q),
    .MDR_q(MDR_q),
    .MAR_addr(MAR_addr),
    .HI_q(HI_q),
    .LO_q(LO_q),
    .Y_q(Y_q),
    .Z_q(Z_q)
);


// Clock generation
initial begin
    clock = 0;
    forever #10 clock = ~clock;   // 20ns period
end


// Test sequence
initial begin

    // ---------- Reset ----------
    clear = 1;
    Rin = 0; Rout = 0;
    PCin=0; PCout=0;
    IRin=0; IRout=0;
    MARin=0; MDRin=0; MDRout=0;
    HIin=0; HIout=0;
    LOin=0; LOout=0;
    Yin=0; Zin=0;
    Zhighout=0; Zlowout=0;
    read=0;
    ALUop=0;
    Mdatain=0;

    #25 clear = 0;


    // =========================================================
    // TEST 1: Load R2 = 10
    // =========================================================
    Mdatain = 32'd10;
    read = 1;
    MDRin = 1;   #20;
    MDRin = 0;

    MDRout = 1;
    Rin[2] = 1;  #20;
    MDRout = 0;
    Rin[2] = 0;


    // =========================================================
    // TEST 2: Load R3 = 3
    // =========================================================
    Mdatain = 32'd3;
    MDRin = 1;   #20;
    MDRin = 0;

    MDRout = 1;
    Rin[3] = 1;  #20;
    MDRout = 0;
    Rin[3] = 0;


    // =========================================================
    // TEST 3: ADD R2 + R3 → R1
    // =========================================================
    Rout[2] = 1; Yin = 1;   #20;
    Rout[2] = 0; Yin = 0;

    Rout[3] = 1;
    ALUop = 5'd0;    // ADD
    Zin = 1;         #20;
    Rout[3] = 0; Zin = 0;

    Zlowout = 1;
    Rin[1] = 1;      #20;
    Zlowout = 0; Rin[1] = 0;


    // =========================================================
    // TEST 4: MUL R2 * R3 → HI/LO
    // =========================================================
    Rout[2] = 1; Yin = 1;   #20;
    Rout[2] = 0; Yin = 0;

    Rout[3] = 1;
    ALUop = 5'd11;   // MUL
    Zin = 1;         #20;
    Rout[3] = 0; Zin = 0;

    HIin = 1; LOin = 1;   #20;
    HIin = 0; LOin = 0;


    // =========================================================
    // TEST 5: DIV R2 / R3 → HI(rem) / LO(quot)
    // =========================================================
    Rout[2] = 1; Yin = 1;   #20;
    Rout[2] = 0; Yin = 0;

    Rout[3] = 1;
    ALUop = 5'd12;   // DIV
    Zin = 1;         #20;
    Rout[3] = 0; Zin = 0;

    HIin = 1; LOin = 1;   #20;
    HIin = 0; LOin = 0;


    #100 $stop;

end

endmodule