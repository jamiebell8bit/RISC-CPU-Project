// 32x32 -> 64 Multiplier (shift-add)
// Group: 22

module mul (
    input  [31:0] A,
    input  [31:0] B,
    output [63:0] P
);
    wire signA = A[31];
    wire signB = B[31];
    wire signP = signA ^ signB;

    // absolute values (algorithm module; two's complement)
    wire [31:0] Au = signA ? (~A + 32'd1) : A;
    wire [31:0] Bu = signB ? (~B + 32'd1) : B;

    reg  [63:0] acc;
    integer i;

    always @(*) begin
        acc = 64'b0;
        for (i = 0; i < 32; i = i + 1) begin
            if (Bu[i]) acc = acc + ({32'b0, Au} << i);
        end
    end

    wire [63:0] unsignedP = acc;
    assign P = signP ? (~unsignedP + 64'd1) : unsignedP;

endmodule