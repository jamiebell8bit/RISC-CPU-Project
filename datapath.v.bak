// Datapath code
// Group: 22

module datapath (
    input clock,
    input clear,

    // General-purpose register controls
    input [15:0] Rin,
    input [15:0] Rout,

    // Special register controls
    input PCin, PCout,
    input IRin, IRout,
    input MARin,
    input MDRin, MDRout,
    input HIin, HIout,
    input LOin, LOout,
    input Yin,
    input Zin,
    input Zhighout,
    input Zlowout,

    // MDR control (read selects Mdatain vs BusMuxOut)
    input read,

    // ALU control
    input [4:0] ALUop,

    // Memory input
    input [31:0] Mdatain,

    // Useful outputs for demo/waveforms
    output [31:0] BusMuxOut,
    output [31:0] IR_q,
    output [31:0] MDR_q,
    output [8:0]  MAR_addr,
    output [31:0] HI_q,
    output [31:0] LO_q,
    output [31:0] Y_q,
    output [63:0] Z_q
);

    // ----------------------------
    // Internal wires
    // ----------------------------
    wire [31:0] R_q [15:0];

    wire [63:0] ALU_result;
    wire [31:0] Zhigh = Z_q[63:32];
    wire [31:0] Zlow  = Z_q[31:0];

    // ----------------------------
    // R0–R15 Registers
    // ----------------------------
    genvar i;
    generate
        for (i = 0; i < 16; i = i + 1) begin : GP_REGS
            register #(32,32,32'h0) Rn (
                .clear(clear),
                .clock(clock),
                .enable(Rin[i]),
                .BusMuxOut(BusMuxOut),
                .BusMuxIn(R_q[i])
            );
        end
    endgenerate

    // ----------------------------
    // PC
    // ----------------------------
    wire [31:0] PC_q;
    register #(32,32,32'h0) PC (
        .clear(clear),
        .clock(clock),
        .enable(PCin),
        .BusMuxOut(BusMuxOut),
        .BusMuxIn(PC_q)
    );

    // ----------------------------
    // IR / MAR / MDR (use your existing modules)
    // ----------------------------
    IR IR0 (
        .clear(clear),
        .clock(clock),
        .IRin(IRin),
        .BusMuxOut(BusMuxOut),
        .IR(IR_q)
    );

    MAR MAR0 (
        .clear(clear),
        .clock(clock),
        .MARin(MARin),
        .BusMuxOut(BusMuxOut),
        .Address(MAR_addr)
    );

    MDR MDR0 (
        .clear(clear),
        .clock(clock),
        .MDRin(MDRin),
        .read(read),
        .BusMuxOut(BusMuxOut),
        .Mdatain(Mdatain),
        .MDR(MDR_q)
    );

    // ----------------------------
    // HI / LO
    // ----------------------------
    register #(32,32,32'h0) HI (
        .clear(clear),
        .clock(clock),
        .enable(HIin),
        .BusMuxOut(Zhigh),
        .BusMuxIn(HI_q)
    );

    register #(32,32,32'h0) LO (
        .clear(clear),
        .clock(clock),
        .enable(LOin),
        .BusMuxOut(Zlow),
        .BusMuxIn(LO_q)
    );

    // ----------------------------
    // Y (operand register)
    // ----------------------------
    register #(32,32,32'h0) Y (
        .clear(clear),
        .clock(clock),
        .enable(Yin),
        .BusMuxOut(BusMuxOut),
        .BusMuxIn(Y_q)
    );

    // ----------------------------
    // ALU + Z
    // ----------------------------
    alu ALU0 (
        .A(Y_q),
        .B(BusMuxOut),
        .ALUop(ALUop),
        .Z(ALU_result)
    );

    register64 #(64,64,64'h0) Z (
        .clear(clear),
        .clock(clock),
        .enable(Zin),
        .BusMuxOut(ALU_result),
        .BusMuxIn(Z_q)
    );

    // ----------------------------
    // BUS (your priority mux bus)
    // ----------------------------
    Bus BUS0 (
        .R0(R_q[0]),  .R1(R_q[1]),  .R2(R_q[2]),  .R3(R_q[3]),
        .R4(R_q[4]),  .R5(R_q[5]),  .R6(R_q[6]),  .R7(R_q[7]),
        .R8(R_q[8]),  .R9(R_q[9]),  .R10(R_q[10]),.R11(R_q[11]),
        .R12(R_q[12]),.R13(R_q[13]),.R14(R_q[14]),.R15(R_q[15]),

        .PC(PC_q),
        .IR(IR_q),
        .MDR(MDR_q),
        .HI(HI_q),
        .LO(LO_q),
        .Zhigh(Zhigh),
        .Zlow(Zlow),

        .R0out(Rout[0]),  .R1out(Rout[1]),  .R2out(Rout[2]),  .R3out(Rout[3]),
        .R4out(Rout[4]),  .R5out(Rout[5]),  .R6out(Rout[6]),  .R7out(Rout[7]),
        .R8out(Rout[8]),  .R9out(Rout[9]),  .R10out(Rout[10]),.R11out(Rout[11]),
        .R12out(Rout[12]),.R13out(Rout[13]),.R14out(Rout[14]),.R15out(Rout[15]),

        .PCout(PCout),
        .IRout(IRout),
        .MDRout(MDRout),
        .HIout(HIout),
        .LOout(LOout),
        .Zhighout(Zhighout),
        .Zlowout(Zlowout),

        .BusOut(BusMuxOut)
    );

endmodule